\section{Appendices}

\subsection{Appendix A: Installation Guide}

\begin{enumerate}
	\item Clone repository:
	      \begin{verbatim}
git clone https://github.com/dtm-drainage-ai
cd dtm-drainage-ai
    \end{verbatim}

	\item Create virtual environment:
	      \begin{verbatim}
python -m venv dtm-env
dtm-env\Scripts\activate  # Windows
# OR: source dtm-env/bin/activate  # Linux/Mac
    \end{verbatim}

	\item Install PDAL:
	      \begin{verbatim}
# Windows: Use QGIS bundled PDAL or download from:
# https://pdal.io/en/latest/download.html

# Update _QGIS_BIN path in ground_classifier.py 
# if using a different installation path
    \end{verbatim}

	\item Install Python dependencies:
	      \begin{verbatim}
pip install -r requirements.txt
    \end{verbatim}

	\item (Optional) GPU support for PointNet:
	      \begin{verbatim}
pip install torch torchvision --index-url \
  https://download.pytorch.org/whl/cu121
    \end{verbatim}
\end{enumerate}

\subsection{Appendix B: Configuration Parameters}

All parameters are defined in \texttt{config/config.yaml}. Key sections:

\begin{itemize}
	\item \texttt{dtm.resolution}: DTM pixel size (default: 0.5 m)
	\item \texttt{waterlogging.threshold}: Probability cutoff for hotspot classification (default: 0.45)
	\item \texttt{drainage.design\_return\_period}: Design storm recurrence (default: 10 years)
	\item \texttt{ground\_classification.smrf.*}: SMRF filter parameters
\end{itemize}

