		\draw[arrow] (s1) -- (s2);
		\draw[arrow] (ml1) -- (s2);

		% Stage 3
		\node[stage] (s3) [right=1.2cm of s2] {Stage 3: DTM Generation};
		\draw[arrow] (s2) -- (s3);

		% Stage 4
