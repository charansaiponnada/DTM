		\node[ml] (s5) [right=1.2cm of s4] {Stage 5: Waterlogging Prediction};
		\draw[arrow] (s4) -- (s5);

		% Stage 6
		\node[stage] (s6) [right=1.2cm of s5] {Stage 6: Drainage Design};
		\draw[arrow] (s5) -- (s6);

		% Outputs
		\node[output, below=1.2cm of s3] (out1) {DTM (COG)};
